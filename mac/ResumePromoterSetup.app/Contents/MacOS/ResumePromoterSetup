#!/bin/bash
# Double-click launcher for setup.sh. Expects to live at <repo>/mac/
# and resolves setup.sh at <repo>/setup.sh (one level above the mac/ dir).
set -e

MACOS_DIR="$(cd "$(dirname "$0")" && pwd)"

# macOS App Translocation: apps launched from a Downloads-style location
# with a quarantine attribute are run from a randomized read-only path
# under /private/var/folders/.../AppTranslocation/. In that state our
# relative walk points at the wrong place, so detect it and explain.
case "$MACOS_DIR" in
    /private/var/folders/*/AppTranslocation/*)
        /usr/bin/osascript <<'APPLESCRIPT'
display dialog "macOS moved this app to a temporary location because it was downloaded from the internet (this is called App Translocation).

Two ways to fix it:

1. In Finder, drag the whole folder that contains this app (for example 'resume-promoter-main') out of Downloads into another location like Documents. Then re-open the app.

2. Or open Terminal (Applications → Utilities → Terminal), paste this and press Return:

     xattr -dr com.apple.quarantine ~/Downloads/resume-promoter-main

(adjust the path if you unzipped elsewhere), then re-open the app." with title "Resume Promoter Setup" buttons {"OK"} default button "OK" with icon stop
APPLESCRIPT
        exit 1
        ;;
esac

# MacOS/ -> Contents/ -> ResumePromoterSetup.app/ -> mac/ -> repo root
REPO_DIR="$(cd "$MACOS_DIR/../../../.." && pwd)"
SETUP="$REPO_DIR/setup.sh"

if [ ! -x "$SETUP" ]; then
    /usr/bin/osascript <<APPLESCRIPT
display dialog "Setup script not found at:
$SETUP

The app must stay inside the 'mac' folder of the resume-promoter project (setup.sh lives one level above). If you moved it, put it back. If you unzipped fresh and still see this, try re-downloading the project." with title "Resume Promoter Setup" buttons {"OK"} default button "OK" with icon stop
APPLESCRIPT
    exit 1
fi

exec "$SETUP"
